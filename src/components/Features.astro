---
import { useTranslations, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

/** Each row’s copy is written for the screenshot it shows — keep them paired. */
const features = [
  {
    key: 'browse',
    title: t('features.browse.title'),
    description: t('features.browse.description'),
    label: t('features.browse.eyebrow'),
    src: 'browse.png',
    srcDark: 'browse-dark.png',
    alt: t('features.browse.shotAlt'),
    reverse: false,
  },
  {
    key: 'filter',
    title: t('features.filter.title'),
    description: t('features.filter.description'),
    label: t('features.filter.eyebrow'),
    src: 'filter-panel.png',
    srcDark: null as string | null,
    alt: t('features.filter.shotAlt'),
    reverse: true,
  },
  {
    key: 'files',
    title: t('features.files.title'),
    description: t('features.files.description'),
    label: t('features.files.eyebrow'),
    src: 'file-preview.png',
    srcDark: null as string | null,
    alt: t('features.files.shotAlt'),
    reverse: false,
  },
  {
    key: 'home',
    title: t('features.home.title'),
    description: t('features.home.description'),
    label: t('features.home.eyebrow'),
    src: 'home-feed.png',
    srcDark: null as string | null,
    alt: t('features.home.shotAlt'),
    reverse: true,
  },
  {
    key: 'spaces',
    title: t('features.spaces.title'),
    description: t('features.spaces.description'),
    label: t('features.spaces.eyebrow'),
    src: 'spaces-gallery.png',
    srcDark: null as string | null,
    alt: t('features.spaces.shotAlt'),
    reverse: false,
  },
] as const;
---

<section
  id="features"
  class="border-b border-line px-4 py-20 sm:px-6 sm:py-28"
  aria-label={t('features.region')}
>
  <div class="mx-auto max-w-6xl space-y-20 sm:space-y-28">
    {
      features.map((f) => (
        <article
          data-feature
          class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16"
        >
          <div
            data-feature-copy
            class:list={['max-w-xl will-change-transform', f.reverse && 'lg:order-2']}
          >
            <p class="font-mono text-xs font-medium tracking-wide text-faint uppercase">
              {f.label}
            </p>
            <h2 class="mt-3 font-display text-2xl font-semibold tracking-tight text-paper sm:text-3xl">
              {f.title}
            </h2>
            <p class="mt-4 text-base leading-relaxed text-body">{f.description}</p>
          </div>
          <div
            data-feature-shot
            class:list={['min-w-0 will-change-transform', f.reverse && 'lg:order-1']}
          >
            <figure class="shot-frame">
              <img
                src={`${base}/${f.src}`}
                alt={f.alt}
                width="1600"
                height="1000"
                loading="lazy"
                class:list={[f.srcDark ? 'shot-light' : null, 'h-auto w-full']}
              />
              {f.srcDark ? (
                <img
                  src={`${base}/${f.srcDark}`}
                  alt={f.alt}
                  width="1600"
                  height="1000"
                  loading="lazy"
                  class="shot-dark h-auto w-full"
                />
              ) : null}
            </figure>
          </div>
        </article>
      ))
    }
  </div>
</section>
