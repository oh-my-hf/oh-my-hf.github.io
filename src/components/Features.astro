---
import { useTranslations, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const features = [
  {
    key: 'browse',
    title: t('features.browse.title'),
    description: t('features.browse.description'),
    label: t('features.browse.eyebrow'),
    src: 'browse.png',
    alt: t('features.browse.shotAlt'),
    reverse: false,
  },
  {
    key: 'home',
    title: t('features.command.title'),
    description: t('features.command.description'),
    label: t('features.command.eyebrow'),
    src: 'filter-panel.png',
    alt: t('features.command.shotAlt'),
    reverse: true,
  },
  {
    key: 'spaces',
    title: t('features.downloads.title'),
    description: t('features.downloads.description'),
    label: t('features.downloads.eyebrow'),
    src: 'file-preview.png',
    alt: t('features.downloads.shotAlt'),
    reverse: false,
  },
  {
    key: 'cache',
    title: t('features.cache.title'),
    description: t('features.cache.description'),
    label: t('features.cache.eyebrow'),
    src: 'home-feed.png',
    alt: t('features.cache.shotAlt'),
    reverse: true,
  },
] as const;
---

<section
  id="features"
  class="border-b border-line px-4 py-20 sm:px-6 sm:py-28"
  aria-label={t('features.region')}
>
  <div class="mx-auto max-w-6xl space-y-20 sm:space-y-28">
    {
      features.map((f) => (
        <article
          data-feature
          class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16"
        >
          <div
            data-feature-copy
            class:list={['max-w-xl will-change-transform', f.reverse && 'lg:order-2']}
          >
            <p class="font-mono text-xs font-medium tracking-wide text-faint uppercase">
              {f.label}
            </p>
            <h2 class="mt-3 font-display text-2xl font-semibold tracking-tight text-paper sm:text-3xl">
              {f.title}
            </h2>
            <p class="mt-4 text-base leading-relaxed text-body">{f.description}</p>
          </div>
          <div
            data-feature-shot
            class:list={['min-w-0 will-change-transform', f.reverse && 'lg:order-1']}
          >
            <figure class="shot-frame">
              <img
                src={`${base}/${f.src}`}
                alt={f.alt}
                width="1600"
                height="1000"
                loading="lazy"
                class="h-auto w-full"
              />
            </figure>
          </div>
        </article>
      ))
    }
  </div>
</section>
