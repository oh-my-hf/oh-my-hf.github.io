---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from './Header.astro';
import Hero from './Hero.astro';
import PainPoint from './PainPoint.astro';
import Features from './Features.astro';
import ComingSoon from './ComingSoon.astro';
import Trust from './Trust.astro';
import Download from './Download.astro';
import FAQ from './FAQ.astro';
import type { Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<BaseLayout locale={locale}>
  <Header locale={locale} />
  <main>
    <Hero locale={locale} />
    <PainPoint locale={locale} />
    <Features locale={locale} />
    <ComingSoon locale={locale} />
    <Trust locale={locale} />
    <Download locale={locale} />
    <FAQ locale={locale} />
  </main>
</BaseLayout>
