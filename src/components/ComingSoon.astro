---
import { useTranslations, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const cards = [
  {
    title: t('comingSoon.inbox.title'),
    description: t('comingSoon.inbox.description'),
  },
  {
    title: t('comingSoon.compare.title'),
    description: t('comingSoon.compare.description'),
  },
  {
    title: t('comingSoon.toolchain.title'),
    description: t('comingSoon.toolchain.description'),
  },
] as const;
---

<section
  data-roadmap
  class="border-b border-line px-4 py-20 sm:px-6 sm:py-28"
  aria-label={t('comingSoon.region')}
>
  <div class="mx-auto max-w-6xl">
    <header data-section-head class="max-w-xl will-change-transform">
      <p class="font-mono text-xs font-medium tracking-wide text-faint uppercase">
        {t('comingSoon.eyebrow')}
      </p>
      <h2
        class="mt-3 font-display text-2xl font-semibold tracking-tight text-paper sm:text-3xl"
      >
        {t('comingSoon.title')}
      </h2>
    </header>

    <ul class="mt-12 grid gap-4 sm:grid-cols-3">
      {
        cards.map((card) => (
          <li
            data-roadmap-card
            class="relative rounded-lg border border-line bg-panel p-6 will-change-transform sm:p-8"
          >
            <span class="absolute top-4 right-4 font-mono text-[10px] font-medium tracking-wide text-iris uppercase sm:top-5 sm:right-5">
              {t('comingSoon.badge')}
            </span>
            <h3 class="pr-24 font-display text-lg font-semibold tracking-tight text-paper">
              {card.title}
            </h3>
            <p class="mt-3 text-sm leading-relaxed text-body">{card.description}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
